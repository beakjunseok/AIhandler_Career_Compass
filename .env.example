# GEMINI_API_KEY: Required for Gemini AI API calls (server-side only).
# Set this in Vercel project env vars. Never expose to the client.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# CAREERNET_API_KEY: 커리어넷 오픈 API 키 (server-side only)
# https://www.career.go.kr/cnet/openapi/getApiKey.do 에서 발급 가능
CAREERNET_API_KEY="YOUR_CAREERNET_API_KEY"

# Supabase (client-safe — VITE_ prefix exposes to browser bundle)
VITE_SUPABASE_URL="https://YOUR_PROJECT_REF.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"
